params {
    samplesheet          = "${projectDir}/samples.tsv"
    outdir               = "${projectDir}/test_run/results"

    model_file           = "/home/desv/novotax/assets/models/XuanjiNovo_130M_massnet_massivekb.ckpt"
    cascadia_model_file  = "/home/desv/novotax/assets/models/cascadia_model_file_here"

    mode                 = "denovo"
}

docker.enabled = true

process {
    executor = 'local'

    withName: RUN_XUANJINOVO {
        container = 'densve/xuanjinovo-novotax:cuda11_v1.1.1'
        containerOptions = '--gpus all'
        cpus = 4
        memory = '12 GB'
    }

    withName: RUN_CASCADIA {
        container = 'densve/cascadia-novotax:cuda11_v1.1'
        containerOptions = '--gpus all'
        cpus = 4
        memory = '12 GB'
    }
}
