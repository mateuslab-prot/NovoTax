params {
    samplesheet           = "${projectDir}/samples.tsv"
    outdir                = "${projectDir}/demo_results"

    xuanjinovo_model_file = null
    cascadia_model_file   = null

    mode                  = "denovo"
}

docker.enabled = false

apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = "${projectDir}/.apptainer_cache"
}

process {
    executor = 'local'

    withName: RUN_XUANJINOVO_WITH_MODEL {
        container = 'docker://densve/xuanjinovo-novotax:cuda11_v1.1.2'
        containerOptions = '--nv'
        cpus = 4
        memory = '12 GB'
    }

    withName: RUN_XUANJINOVO_DEFAULT_MODEL {
        container = 'docker://densve/xuanjinovo-novotax:cuda11_v1.1.2'
        containerOptions = '--nv'
        cpus = 4
        memory = '12 GB'
    }

    withName: RUN_CASCADIA_WITH_MODEL {
        container = 'docker://densve/cascadia-novotax:cuda11_v1.1'
        containerOptions = '--nv'
        cpus = 4
        memory = '12 GB'
    }

    withName: RUN_CASCADIA_DEFAULT_MODEL {
        container = 'docker://densve/cascadia-novotax:cuda11_v1.1'
        containerOptions = '--nv'
        cpus = 4
        memory = '12 GB'
    }

    withName: RUN_NOVOTAX {
        container = 'docker://densve/novotax:peptides'
        cpus = 4
        memory = '16 GB'
    }
}

profiles {
    docker_gpu {
        docker.enabled = true
        apptainer.enabled = false

        process {
            withName: RUN_XUANJINOVO_WITH_MODEL {
                container = 'densve/xuanjinovo-novotax:cuda11_v1.1.2'
                containerOptions = '--gpus all'
            }

            withName: RUN_XUANJINOVO_DEFAULT_MODEL {
                container = 'densve/xuanjinovo-novotax:cuda11_v1.1.2'
                containerOptions = '--gpus all'
            }

            withName: RUN_CASCADIA_WITH_MODEL {
                container = 'densve/cascadia-novotax:cuda11_v1.1'
                containerOptions = '--gpus all'
            }

            withName: RUN_CASCADIA_DEFAULT_MODEL {
                container = 'densve/cascadia-novotax:cuda11_v1.1'
                containerOptions = '--gpus all'
            }

            withName: RUN_NOVOTAX {
                container = 'densve/novotax:peptides'
            }
        }
    }

    apptainer_wsl_gpu {
        docker.enabled = false
        apptainer.enabled = true

        process {
            withName: RUN_XUANJINOVO_WITH_MODEL {
                container = 'docker://densve/xuanjinovo-novotax:cuda11_v1.1.2'
                containerOptions = '--nv --nvccli'
                cpus = 4
                memory = '12 GB'
            }

            withName: RUN_XUANJINOVO_DEFAULT_MODEL {
                container = 'docker://densve/xuanjinovo-novotax:cuda11_v1.1.2'
                containerOptions = '--nv --nvccli'
                cpus = 4
                memory = '12 GB'
            }

            withName: RUN_CASCADIA_WITH_MODEL {
                container = 'docker://densve/cascadia-novotax:cuda11_v1.1'
                containerOptions = '--nv --nvccli'
                cpus = 4
                memory = '12 GB'
            }

            withName: RUN_CASCADIA_DEFAULT_MODEL {
                container = 'docker://densve/cascadia-novotax:cuda11_v1.1'
                containerOptions = '--nv --nvccli'
                cpus = 4
                memory = '12 GB'
            }

            withName: RUN_NOVOTAX {
                container = 'docker://densve/novotax:peptides'
                cpus = 4
                memory = '16 GB'
            }
        }
    }
}
